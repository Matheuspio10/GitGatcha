generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  username      String?   @unique
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  currency      Int       @default(1000)
  lastDailyClaimAt DateTime?
  xp            Int       @default(0)
  level         Int       @default(1)
  rating        Int       @default(1000)
  inventory     Json      @default("[]")
  notifications Json      @default("[]")
  seenChangelogs Json     @default("[]")
  pendingRewards Json     @default("[]")
  fragments     Json      @default("{}")
  fragmentLogs  Json      @default("[]")
  wishlist      Json      @default("[]")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  cards         UserCard[]
  missions      UserMission[]
  friendships   Friendship[]    @relation("UserFriendships")
  friendRequests Friendship[]   @relation("FriendRequests")
  battlesAsChallenger Battle[] @relation("Challenger")
  battlesAsDefender   Battle[] @relation("Defender")
}

model Account {
  id                 String  @id @default(uuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Card {
  id             String   @id @default(uuid())
  githubUsername String   @unique
  avatarUrl      String?
  name           String
  flavorText     String
  atk            Int
  def            Int
  hp             Int
  rarity         String
  primaryLanguage String?
  createdAt      DateTime @default(now())

  owners         UserCard[]
  battlesAsChallenger Battle[] @relation("ChallengerCard")
  battlesAsDefender   Battle[] @relation("DefenderCard")
}

model UserCard {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  card      Card     @relation(fields: [cardId], references: [id])
  cardId    String
  quantity  Int      @default(1)
  shards    Int      @default(0)
  isShiny   Boolean  @default(false)
  stamina   Int      @default(100)
  lastUsedAt DateTime @default(now()) @map("last_used_at")
  inActiveTeam Boolean @default(false) @map("in_active_team")
  loyaltyCount      Int      @default(0)
  loyaltyTier       String   @default("none")
  loyaltyMilestones Json     @default("[]")
  lifetimeStats     Json     @default("{}")
  showcaseOrder     Int?
  createdAt DateTime @default(now())
}

model Mission {
  id          String   @id @default(uuid())
  description String
  reward      Int
  type        String
  targetValue String?
  createdAt   DateTime @default(now())

  userMissions UserMission[]
}

model UserMission {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  mission   Mission  @relation(fields: [missionId], references: [id])
  missionId String
  progress  Int      @default(0)
  completed Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Battle {
  id               String        @id @default(uuid())
  challengerId     String
  defenderId       String?
  challengerCardId String?
  defenderCardId   String?
  challengerTeam   Json?
  defenderTeam     Json?
  log              Json?
  status           String        @default("PENDING")
  winnerId         String?
  rewardBits       Int           @default(0)
  isRandom         Boolean       @default(false)
  leagueMode       String        @default("OPEN")
  battleStats      Json?
  expiresAt        DateTime?
  createdAt        DateTime      @default(now())
  completedAt      DateTime?

  challenger       User          @relation("Challenger", fields: [challengerId], references: [id])
  defender         User?         @relation("Defender", fields: [defenderId], references: [id])
  challengerCard   Card?         @relation("ChallengerCard", fields: [challengerCardId], references: [id])
  defenderCard     Card?         @relation("DefenderCard", fields: [defenderCardId], references: [id])
  rounds           BattleRound[]
}

model BattleRound {
  id              String  @id @default(uuid())
  battleId        String
  roundNum        Int
  attribute       String
  challengerValue Int
  defenderValue   Int
  winnerId        String?

  battle          Battle  @relation(fields: [battleId], references: [id], onDelete: Cascade)
}

model Friendship {
  id        String   @id @default(uuid())
  userId    String
  friendId  String
  status    String   @default("PENDING") // PENDING, ACCEPTED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation("UserFriendships", fields: [userId], references: [id], onDelete: Cascade)
  friend    User     @relation("FriendRequests", fields: [friendId], references: [id], onDelete: Cascade)

  @@unique([userId, friendId])
}

model ChangelogEntry {
  id        String   @id @default(uuid())
  version   String
  title     String
  body      String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
